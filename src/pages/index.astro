---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Features from '../components/sections/Features.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Pricing from '../components/sections/Pricing.astro';
import FAQ from '../components/sections/FAQ.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import ChatWidget from '../components/ui/ChatWidget.astro';
---

<BaseLayout
  title="NextWave AI Solutions: Serious AI. Built locally."
  description="We build the AI systems that run your local business. Lead recovery, follow-up automation, client intake, and more. Starting with a free diagnostic."
>
  <Header />
  <main>
    <Hero />
    <Features />
    <HowItWorks />
    <Testimonials />
    <Pricing />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <ChatWidget />

  <script>
    import { initScrollReveal } from '../lib/scrollReveal';
    initScrollReveal();
  </script>
</BaseLayout>
