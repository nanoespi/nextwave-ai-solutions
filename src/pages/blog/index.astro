---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Card from '../../components/ui/Card.astro';
import Tag from '../../components/ui/Tag.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="Blog — Naerix"
  description="Practical writing on AI automation, local business operations, and building systems that run without you."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="blog-hero">
      <div class="container">
        <Tag variant="inverse">The field notes</Tag>
        <h1 class="hero-headline" data-reveal data-reveal-delay="60">Practical writing. No filler.</h1>
        <p class="hero-subhead" data-reveal data-reveal-delay="120">AI automation, local business operations, and building systems that run without you.</p>
      </div>
    </section>

    <!-- Post listing -->
    <section class="blog-listing">
      <div class="container">
        {posts.length === 0 ? (
          <div class="empty-state">
            <p>Posts are coming. Check back soon.</p>
          </div>
        ) : (
          <div class="posts-grid" data-reveal>
            {posts.map((post) => (
              <Card variant="default" class="post-card">
                {post.data.tags.length > 0 && (
                  <Tag variant="default">{post.data.tags[0]}</Tag>
                )}
                <p class="post-date">{formatDate(post.data.publishDate)}</p>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-description">{post.data.description}</p>
                <a href={`/blog/${post.id}`} class="post-link">Read more &#x2192;</a>
              </Card>
            ))}
          </div>
        )}
      </div>
    </section>

  </main>
  <Footer />

  <script>
    import { initScrollReveal } from '../../lib/scrollReveal';
    initScrollReveal();
  </script>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Hero */
  .blog-hero {
    background: var(--bg-ink);
    padding: 160px 0 96px;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink-on-dark);
    margin: 24px 0 20px;
  }

  .hero-subhead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    line-height: 1.65;
    color: var(--ink-on-dark-dim);
    max-width: 560px;
    margin: 0;
  }

  /* Blog listing */
  .blog-listing {
    background: var(--bg-bone);
    padding: 96px 0;
  }

  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--ink-tertiary);
  }

  .empty-state p {
    font-family: var(--font-sans);
    font-size: 1rem;
    margin: 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .post-date {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--ink-tertiary);
    margin: 12px 0 8px;
  }

  .post-title {
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1.5vw, 1.25rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink-primary);
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .post-description {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--ink-secondary);
    margin: 0 0 20px;
  }

  .post-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--ink-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease-brand);
  }

  .post-link:hover {
    color: var(--voltage-deep);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container {
      padding: 0 20px;
    }

    .blog-hero {
      padding: 120px 0 72px;
    }

    .blog-listing {
      padding: 72px 0;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .blog-hero {
      padding: 100px 0 60px;
    }

    .hero-headline {
      font-size: 2rem;
    }
  }
</style>
