---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import Tag from '../components/ui/Tag.astro';

const calLink = import.meta.env.PUBLIC_CAL_LINK ?? 'nextwave-ai/diagnostic';
---

<BaseLayout
  title="Contact — Naerix"
  description="Book a free diagnostic call or send us a message. We respond within one business day."
>
  <Header />
  <main>

    <!-- C1: Hero -->
    <section class="contact-hero">
      <div class="container">
        <Tag variant="inverse">Get in touch</Tag>
        <h1 class="hero-headline" data-reveal data-reveal-delay="60">Start with a conversation.</h1>
        <p class="hero-subhead" data-reveal data-reveal-delay="120">Book a 20-minute Diagnostic Call or send a message below. We respond within one business day.</p>
      </div>
    </section>

    <!-- C2: Two-column contact layout -->
    <section class="contact-section">
      <div class="container">
        <div class="contact-grid">

          <!-- Left: Cal.com inline embed -->
          <div class="contact-col">
            <p class="col-label">BOOK A DIAGNOSTIC CALL</p>
            <div id="cal-embed" data-cal-link={calLink} class="cal-container"></div>
          </div>

          <!-- Right: Contact form -->
          <div class="contact-col">
            <p class="col-label">SEND A MESSAGE</p>
            <div role="form" id="contact-form" aria-label="Contact form">
              <div class="field">
                <label for="name" class="field-label">Your name <span class="required-mark" aria-hidden="true">*</span></label>
                <input type="text" id="name" name="name" required placeholder="Your name" class="field-input" autocomplete="name" />
              </div>
              <div class="field">
                <label for="business-name" class="field-label">Business name <span class="required-mark" aria-hidden="true">*</span></label>
                <input type="text" id="business-name" name="businessName" required placeholder="Business name" class="field-input" autocomplete="organization" />
              </div>
              <div class="field">
                <label for="email" class="field-label">Email <span class="required-mark" aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required placeholder="your@email.com" class="field-input" autocomplete="email" />
              </div>
              <div class="field">
                <label for="phone" class="field-label">Phone <span class="field-optional">(optional)</span></label>
                <input type="tel" id="phone" name="phone" placeholder="(870) 000-0000" class="field-input" autocomplete="tel" />
              </div>
              <div class="field">
                <label for="message" class="field-label">Message <span class="required-mark" aria-hidden="true">*</span></label>
                <textarea id="message" name="message" required rows="5" placeholder="What's costing you the most right now?" class="field-input field-textarea"></textarea>
              </div>
              <p id="form-error" class="form-error" hidden>
                Something went wrong. Email us directly at <a href="mailto:hello@nextwaveaisolutions.com">hello@nextwaveaisolutions.com</a>
              </p>
              <Button variant="primary" id="submit-btn">Send Message</Button>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    import { initScrollReveal } from '../lib/scrollReveal';
    initScrollReveal();

    // Cal.com inline embed
    const calEmbedEl = document.getElementById('cal-embed');
    const calLink = calEmbedEl?.dataset.calLink || 'nextwave-ai/diagnostic';
    window.addEventListener('load', function () {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const Cal = (window as any).Cal;
      if (!Cal) return;
      Cal('inline', {
        elementOrSelector: '#cal-embed',
        calLink: calLink,
        layout: 'month_view',
      });
    });

    // Contact form submit handler
    async function handleSubmit(e: Event) {
      e.preventDefault();
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      const formError = document.getElementById('form-error') as HTMLParagraphElement | null;
      if (!submitBtn) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      const payload = {
        name: (document.getElementById('name') as HTMLInputElement).value,
        businessName: (document.getElementById('business-name') as HTMLInputElement).value,
        email: (document.getElementById('email') as HTMLInputElement).value,
        phone: (document.getElementById('phone') as HTMLInputElement).value,
        message: (document.getElementById('message') as HTMLTextAreaElement).value,
      };

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          const form = document.getElementById('contact-form');
          if (form) {
            form.innerHTML = '<p style="font-size:1rem;color:var(--ink-primary);line-height:1.75;padding:24px 0">Message received. We will respond within one business day.</p>';
          }
        } else {
          throw new Error('non-200');
        }
      } catch {
        if (formError) formError.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    }

    document.getElementById('submit-btn')?.addEventListener('click', handleSubmit);
  </script>
</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Hero */
  .contact-hero {
    background: var(--bg-ink);
    padding: 160px 0 96px;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink-on-dark);
    margin: 24px 0 20px;
  }

  .hero-subhead {
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1.5vw, 1.1875rem);
    line-height: 1.65;
    color: var(--ink-on-dark-dim);
    max-width: 560px;
    margin: 0;
  }

  /* Contact section */
  .contact-section {
    background: var(--bg-bone);
    padding: 96px 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .contact-col {
    min-width: 0;
  }

  .col-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-tertiary);
    margin: 0 0 20px;
  }

  /* Cal.com embed */
  .cal-container {
    width: 100%;
    min-height: 600px;
    border-radius: 8px;
    overflow: hidden;
  }

  /* Form fields */
  .field {
    margin-bottom: 20px;
  }

  .field-label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink-primary);
    margin-bottom: 6px;
  }

  .required-mark {
    color: var(--ink-tertiary);
  }

  .field-optional {
    font-weight: 400;
    color: var(--ink-tertiary);
  }

  .field-input {
    display: block;
    width: 100%;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--ink-primary);
    background: var(--bg-bone-cool);
    border: 1px solid rgba(10, 14, 26, 0.16);
    border-radius: 6px;
    padding: 10px 14px;
    outline: none;
    transition: border-color var(--dur-fast) var(--ease-brand),
                box-shadow var(--dur-fast) var(--ease-brand);
    box-sizing: border-box;
  }

  .field-input::placeholder {
    color: var(--ink-tertiary);
  }

  .field-input:focus {
    border-color: var(--ink-primary);
    box-shadow: 0 0 0 3px rgba(10, 14, 26, 0.08);
  }

  .field-textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.6;
  }

  /* Error state */
  .form-error {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--ink-secondary);
    margin: 0 0 16px;
  }

  .form-error a {
    color: var(--ink-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 20px;
    }

    .contact-hero {
      padding: 120px 0 72px;
    }

    .contact-section {
      padding: 72px 0;
    }
  }

  @media (max-width: 480px) {
    .contact-hero {
      padding: 100px 0 60px;
    }

    .hero-headline {
      font-size: 2rem;
    }
  }
</style>
