---
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__grid">
    <div class="footer-col footer-col--brand">
      <a href="/" class="footer-logo" aria-label="Naerix home">
        <img src="/images/wordmark-dark.svg" alt="Naerix" class="footer-wordmark" />
      </a>
      <p class="footer-tagline">Serious AI. Built locally.</p>
    </div>

    <div class="footer-col">
      <p class="footer-col__label">Services</p>
      <nav aria-label="Services links">
        <a href="#services" class="footer-link">Lead Recovery</a>
        <a href="#services" class="footer-link">Follow-Up Automation</a>
        <a href="#services" class="footer-link">Client Intake</a>
        <a href="#services" class="footer-link">Reporting</a>
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-col__label">Company</p>
      <nav aria-label="Company links">
        <a href="#about" class="footer-link">About</a>
        <a href="#contact" class="footer-link">Contact</a>
        <a href="#blog" class="footer-link">Blog</a>
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-col__label">Get Started</p>
      <nav aria-label="Get started links">
        <a href="#contact" class="footer-link footer-link--voltage">Book a Diagnostic</a>
      </nav>
    </div>
  </div>

  <div class="site-footer__bar">
    <p class="footer-legal">&copy; 2026 Naerix, LLC</p>
    <p class="footer-location">Built in Jonesboro, AR</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-ink-deep);
    padding: 80px 32px 32px;
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    max-width: var(--max-width);
    margin: 0 auto 64px;
  }

  /* Brand column */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    margin-bottom: 12px;
  }

  .footer-wordmark {
    height: 34px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-on-dark-soft);
    margin: 0;
    line-height: 1.5;
  }

  /* Column labels */
  .footer-col__label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-on-dark-soft);
    margin: 0 0 16px;
  }

  /* Footer links */
  .footer-col nav {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-on-dark-dim);
    text-decoration: none;
    transition: color var(--dur-fast) ease-out;
  }

  .footer-link:hover {
    color: var(--ink-on-dark);
  }

  .footer-link--voltage {
    color: var(--voltage);
  }

  .footer-link--voltage:hover {
    color: var(--voltage-bright);
  }

  /* Bottom bar */
  .site-footer__bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid var(--rule-on-dark);
  }

  .footer-legal,
  .footer-location {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-on-dark-soft);
    margin: 0;
  }

  @media (max-width: 900px) {
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .footer-col--brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .site-footer {
      padding: 56px 20px 24px;
    }

    .site-footer__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-col--brand {
      grid-column: span 1;
    }

    .site-footer__bar {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>
