---
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import Button from '../ui/Button.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import pricingData from '../../data/pricing.json';

type TagVariant = 'default' | 'voltage' | 'inverse' | 'artifact';
type ButtonVariant = 'primary' | 'voltage' | 'ghost' | 'inverse-ghost';

interface PricingTier {
  name: string;
  tag: string;
  tagVariant: TagVariant;
  price: string;
  cadence: string;
  description: string;
  features: string[];
  cta: string;
  ctaVariant: ButtonVariant;
  highlighted: boolean;
}

const tiers = pricingData as PricingTier[];
const calLink = import.meta.env.PUBLIC_CAL_LINK;
---

<section class="pricing" id="pricing">
  <div class="pricing__inner">
    <SectionHeader
      eyebrow="Pricing"
      headline="One engagement. One system. Priced for local business."
      align="left"
    />

    <div class="pricing__grid">
      {tiers.map((tier) => (
        <div class:list={['pricing-card-wrap', { 'pricing-card-wrap--highlighted': tier.highlighted }]}>
          <Card variant="default" class="pricing-card">
            <div class="pricing-card__header">
              <Tag variant={tier.tagVariant}>{tier.tag}</Tag>
              <div class="pricing-card__price-row">
                <span class="pricing-card__price">{tier.price}</span>
              </div>
              <span class="pricing-card__cadence">{tier.cadence}</span>
            </div>

            <p class="pricing-card__desc">{tier.description}</p>

            <ul class="pricing-card__features" role="list">
              {tier.features.map((feature) => (
                <li class:list={['pricing-card__feature', { 'pricing-card__feature--voltage': feature === 'Scale Kit artifact' }]}>
                  <span class="feature-check" aria-hidden="true"></span>
                  {feature}
                </li>
              ))}
            </ul>

            <Button variant={tier.ctaVariant} class="pricing-card__cta" data-cal-link={calLink} data-cal-config='{"layout":"modal"}' data-track="CTA Clicked">
              {tier.cta}
            </Button>
          </Card>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing {
    background: var(--bg-bone);
    padding: 100px 32px;
  }

  .pricing__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  /* Highlighted (Growth) wrapper adds voltage border */
  .pricing-card-wrap--highlighted .pricing-card {
    border-color: rgba(212, 255, 61, 0.40) !important;
  }

  /* Card internals */
  .pricing-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .pricing-card__header {
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pricing-card__price-row {
    margin-top: 4px;
  }

  .pricing-card__price {
    font-family: var(--font-sans);
    font-size: clamp(32px, 3vw, 44px);
    font-weight: 500;
    color: var(--ink-primary);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .pricing-card__cadence {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-tertiary);
    letter-spacing: 0.04em;
    display: block;
    margin-top: -4px;
  }

  .pricing-card__desc {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-secondary);
    line-height: 1.65;
    margin: 0 0 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--rule-hairline);
  }

  /* Feature list */
  .pricing-card__features {
    list-style: none;
    margin: 0 0 32px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .pricing-card__feature {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-secondary);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    line-height: 1.5;
  }

  /* Inline voltage treatment for Scale Kit artifact line */
  .pricing-card__feature--voltage {
    background: rgba(212, 255, 61, 0.12);
    border: 1px solid rgba(212, 255, 61, 0.40);
    color: var(--voltage-ink);
    border-radius: 4px;
    padding: 4px 10px;
    font-weight: 500;
  }

  .feature-check {
    display: inline-block;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--rule-mid);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .pricing-card__feature--voltage .feature-check {
    background: rgba(212, 255, 61, 0.60);
  }

  .pricing-card__cta {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .pricing__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }

  @media (max-width: 600px) {
    .pricing {
      padding: 72px 20px;
    }
  }
</style>
