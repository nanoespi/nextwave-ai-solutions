---
import Button from '../ui/Button.astro';
import Tag from '../ui/Tag.astro';
import EmergentOrder from '../motion/EmergentOrder.astro';

const calLink = import.meta.env.PUBLIC_CAL_LINK;
---

<section class="hero" aria-label="Introduction">
  <EmergentOrder />

  <div class="hero__content">
    <div class="hero__eyebrow" data-reveal>
      <Tag variant="inverse" class="hero-eyebrow-tag">AI Systems for Local Business</Tag>
    </div>

    <h1 class="hero__headline" data-reveal data-reveal-delay="60">
      <span class="headline-line headline-line--primary">Serious AI.</span>
      <span class="headline-line headline-line--voltage">Built locally.</span>
    </h1>

    <p class="hero__subhead" data-reveal data-reveal-delay="120">
      We build the systems that will be running your business in five years. We start next month.
    </p>

    <div class="hero__ctas" data-reveal data-reveal-delay="180">
      <Button variant="voltage" data-cal-link={calLink} data-cal-config='{"layout":"modal"}' data-track="CTA Clicked">Start a Diagnostic</Button>
      <Button variant="inverse-ghost" href="#how-it-works">See How It Works</Button>
    </div>

    <div class="hero__stats" aria-label="Key metrics">
      <div class="stat">
        <span class="stat__number">&lt;&nbsp;48&nbsp;hrs</span>
        <span class="stat__label">Time to first diagnostic</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat__number">100%</span>
        <span class="stat__label">Clarity before you commit</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat__number">$0</span>
        <span class="stat__label">Upfront to start</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    background: var(--bg-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 120px 32px 80px;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: var(--max-width);
    width: 100%;
  }

  /* Eyebrow */
  .hero__eyebrow {
    margin-bottom: 32px;
  }

  /* Override tag color to match spec */
  .hero-eyebrow-tag {
    color: var(--ink-on-dark-soft) !important;
    font-size: 12px;
    letter-spacing: 0.12em;
  }

  /* Headline */
  .hero__headline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0 0 28px;
    font-size: clamp(56px, 8vw, 112px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.0;
  }

  .headline-line--primary {
    color: var(--ink-on-dark);
    display: block;
  }

  .headline-line--voltage {
    color: var(--voltage);
    display: block;
  }

  /* Subhead */
  .hero__subhead {
    font-size: clamp(17px, 1.5vw, 19px);
    color: var(--ink-on-dark-dim);
    max-width: 560px;
    line-height: 1.65;
    margin: 0 0 40px;
  }

  /* CTAs */
  .hero__ctas {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 72px;
  }

  /* Stats */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    justify-content: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 48px;
  }

  .stat__number {
    font-family: var(--font-sans);
    font-size: clamp(64px, 9vw, 128px);
    font-weight: 500;
    color: var(--ink-on-dark);
    letter-spacing: -0.03em;
    line-height: 1.0;
    display: block;
  }

  .stat__label {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-on-dark-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 6px;
    display: block;
  }

  .stat-divider {
    width: 1px;
    height: 48px;
    background: var(--rule-on-dark);
    flex-shrink: 0;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero {
      padding: 100px 20px 60px;
    }

    .stat {
      padding: 0 24px;
    }

    .hero__stats {
      gap: 16px;
    }

    .stat-divider {
      display: none;
    }
  }
</style>
